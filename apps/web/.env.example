# Minimum runtime
POSTGRES_URL=

# OpenAI (direct API — required for agent / LLM routes)
OPENAI_API_KEY=
# Optional: Azure OpenAI or proxy base URL
# OPENAI_BASE_URL=

# Supabase Auth (sign-in)
# Site URL in Supabase: {YOUR_ORIGIN} — add redirect: {YOUR_ORIGIN}/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
# When the app runs in Docker, loopback Supabase URLs such as
# http://127.0.0.1:54321 are automatically rewritten for server-side access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# Optional: when using sandbox type just-bash (Settings / session), allow emulated curl network access
# JUST_BASH_NETWORK=all
