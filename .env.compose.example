# Copy this file to .env.compose, then run docker compose with:
#   OPEN_AGENTS_ENV_FILE=.env.compose docker compose --env-file .env.compose --profile dev up
#   OPEN_AGENTS_ENV_FILE=.env.compose docker compose --env-file .env.compose --profile prod up -d --build
#
# For local Supabase running on your host via `supabase start`, point the app at:
#   NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
#
# For production metadata/callback URLs, use hostnames only (no scheme), e.g.
#   VERCEL_PROJECT_PRODUCTION_URL=open-agents.example.com

OPEN_AGENTS_PORT=3000

# Required app runtime
OPENAI_API_KEY=
ENCRYPTION_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional deployment metadata
VERCEL_ENV=production
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=

# Optional external Redis / KV. Leave blank to use the bundled redis service.
REDIS_URL=
KV_URL=

# Optional direct Postgres URL for tooling/pages that surface it
POSTGRES_URL=

# Optional GitHub App integration
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional extras
OPENAI_BASE_URL=
ELEVENLABS_API_KEY=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
JUST_BASH_NETWORK=
